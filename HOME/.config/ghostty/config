# cmd+left and cmd+right are hooked by the system
# page top cmd+↑
# page bottom cmd+↓

# ghostty +show-config --default --docs
# ghostty +list-keybinds --default | grep scroll

# mac
macos-option-as-alt = true
# for zellij
keybind = alt+left=unbind
keybind = alt+right=unbind

# color
foreground = 00ff00
background = 000000
cursor-color = aaaaaa

# https://github.com/ghostty-org/ghostty/discussions/11973
resize-overlay = never
