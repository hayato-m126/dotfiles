[user]
  name = Hayato Mizushima
  email = hayato-m126@users.noreply.github.com
# for autoware
# [url "git@github.com:"]
#   insteadOf = https://github.com/
[ghq]
  root = ~/ghq
[filter "lfs"]
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  process = git-lfs filter-process
  required = true
[init]
  defaultbranch = main
[core]
  editor = nano
[credential "https://github.com"]
	helper = 
	helper = !/home/hyt/.local/share/mise/installs/github-cli/2.89.0/gh_2.89.0_linux_amd64/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/home/hyt/.local/share/mise/installs/github-cli/2.89.0/gh_2.89.0_linux_amd64/bin/gh auth git-credential
